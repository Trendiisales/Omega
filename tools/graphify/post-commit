#!/bin/sh
# graphify-omega-hook — after each commit, fully reindex (code + local-Ollama docs),
# integrity-test, and stamp the knowledge graph. Detached so `git commit` returns instantly.
# Installed by tools/graphify/install-automation.sh. Source of truth: tools/graphify/refresh.sh.
export PYTHONHASHSEED=0

GIT_DIR=$(git rev-parse --git-dir 2>/dev/null)
# skip mid-rebase/merge/cherry-pick so we never block --continue
[ -d "$GIT_DIR/rebase-merge" ] && exit 0
[ -d "$GIT_DIR/rebase-apply" ] && exit 0
[ -f "$GIT_DIR/MERGE_HEAD" ] && exit 0
[ -f "$GIT_DIR/CHERRY_PICK_HEAD" ] && exit 0
[ "${GRAPHIFY_SKIP_HOOK:-0}" = "1" ] && exit 0

# skip if only graphify-out/ artifacts changed (no real source change -> no rebuild loop)
CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null || git diff --name-only HEAD 2>/dev/null)
NON_GRAPH=$(printf '%s\n' "$CHANGED" | grep -v '^graphify-out/' || true)
[ -z "$NON_GRAPH" ] && exit 0

REPO=$(git rev-parse --show-toplevel 2>/dev/null)
[ -x "$REPO/tools/graphify/refresh.sh" ] || exit 0
LOG="${HOME}/.cache/graphify-rebuild.log"
mkdir -p "$(dirname "$LOG")"
echo "[graphify hook] $(date) detached reindex+test+stamp (log: $LOG)"
# detach so the commit returns immediately; refresh.sh re-extracts, tests, stamps
( setsid "$REPO/tools/graphify/refresh.sh" >>"$LOG" 2>&1 & ) 2>/dev/null \
  || ( nohup "$REPO/tools/graphify/refresh.sh" >>"$LOG" 2>&1 & )
exit 0
