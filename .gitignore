# =============================================================================
# .gitignore — written 2026-05-12 (S34 hygiene)
#
# Philosophy:
#   - Source code (.cpp .hpp .py .sh .md) is NEVER ignored except for a few
#     explicitly-listed operator helper scripts.
#   - Everything else — built binaries, sweep outputs, market-data captures,
#     logs, archives, OS junk — is ignored.
#   - Already-tracked files (e.g. data/l2_ticks_2026-04-16.csv) keep being
#     tracked; .gitignore only affects future `git add` of new files.
# =============================================================================

# ── SECRETS — never commit ────────────────────────────────────────────────────
.github_token
.env
*.pem
*.key
*.crt
secrets/

# ── OS / editor junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ── Archives / installers ─────────────────────────────────────────────────────
*.zip
*.tar
*.tar.gz
*.tgz
*.dmg
*.iso
Omega-main.zip
Claude.dmg
FIX-4.4-Specification-with-20030618-Errata-44775/
FIX-4.4-Specification-with-20030618-Errata-44775.zip

# ── Build artifacts ───────────────────────────────────────────────────────────
build/
*.o
*.obj
*.a
*.so
*.dylib
*.exe
*.gch
*.pch
include/version_generated.hpp

# ── Python caches ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# ── Logs / inspection / run outputs ───────────────────────────────────────────
*.log
*.out
/inspect_c*.out
/run_*.log
/cfe_post_*.log
/hbg_post_*.log

# ── Operator one-off helper scripts (not part of the codebase) ────────────────
COMMIT_PHASE1.sh
COMMIT_SESSION_*.sh

# ── Market-data captures (large, regenerable from broker, kept locally) ───────
# Note: data/l2_ticks_2026-04-16.csv is already tracked and stays tracked.
data/l2_ticks_*.csv
data/risk_monitor_thresholds.csv
backtest/l2_ticks_*.csv
/l2_ticks_*.csv
/tick_q.csv

# ── Backtest result directories (regenerable) ─────────────────────────────────
outputs/
audit_input/
orb_1m_sweep_results/
sweep_results/
sweep_results_archive_*/
sweep_results_crtp/
sweep_g2_smoke/
sweep_g2_smoke_postfix/
sweep_D6E1_*/
sweep_D7DIAG_*/
sweep_D7FIX2_ST_*/
fvg_phase0/
fvg_phase0_reweight/
fvg_pnl_backtest_v*/
phase2/
incidents/
archive/
bt_nas_results/
backtest/results/
backtest/edgefinder/output/
backtest/baselines/
backtest/nr2_20/
omega-terminal/dist-verify/

# ── Backtest result CSVs in root ──────────────────────────────────────────────
/bt_*.csv
/cfe_duka_bt_trades*.csv
/hbg_duka_bt_trades*.csv
/mce_duka_bt_trades*.csv
# Standalone harness outputs (htf_bt_minimal -- 2026-05-14d/e sessions)
/htf_bt_minimal_*.csv
/htf_bt_minimal_*.txt
# VWAPReversionBacktest smoke-test outputs (S69 P0 default report/trades paths)
/vrev_*.csv
# EmaPullbackBacktest sweep/single-run outputs (part-Y S75-S82 evidence trail
# kept in outputs/; per-run scratch in repo root ignored)
/epb_*.csv
/epb_*.txt
# XauTrendFollowBacktest single-run defaults (part-Z; WF driver writes into
# outputs/xtf_*_t1_p3_<ts>/ which is already covered by the outputs/ rule
# below if applicable, but per-run scratch in repo root ignored here)
/xtf_trades.csv
/xtf_report.csv

